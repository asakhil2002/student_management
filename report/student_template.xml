<odoo>
    <template id="report_student_template">
        <t t-call="web.html_container">
            <div class="page">
                <div class="oe_structure"/>
                <h2 align="center">
                    <b>Student Details</b>
                </h2>
                <br></br>
                <table class="table table-boardered">
                    <thead>
                        <tr>
                            <th>Serial No</th>
                            <th>Ref No</th>
                            <th>Name</th>
                            <th>Age</th>
                            <th>DOB</th>
                            <th>Ph No</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="counter" t-value="0"/>
                        <t t-foreach="docs" t-as="o">
                            <t t-set="counter" t-value="counter + 1"/>
                            <tr>
                                <td align="center">
                                    <t t-esc="counter"/>
                                </td>
                                <td align="left">
                                    <t t-esc="o.ref_id"/>
                                </td>
                                <td align="center">
                                    <t t-esc="o.name"/>
                                </td>
                                <td align="right">
                                    <t t-esc="o.age"/>
                                </td>
                                <td align="center">
                                    <t t-esc="o.date_of_birth"/>
                                </td>
                                <td align="center">
                                    <t t-esc="o.phone"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>
</odoo>