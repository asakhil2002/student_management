<odoo>
    <data>
        <record id="module_akhil_school" model="ir.module.category">
            <field name="name">School Management</field>
            <field name="description">Category for school management modules</field>
            <field name="sequence">10</field>
        </record>
        <record id="group_principal" model="res.groups">
            <field name="name">Principal</field>
<!--            <field name="category_id" ref="student_management.module_akhil_school"/>-->
        </record>
        <record id="group_faculty" model="res.groups">
            <field name="name">Faculty</field>
<!--            <field name="category_id" ref="student_management.module_akhil_school"/>-->
        </record>
        <record id="group_student" model="res.groups">
            <field name="name">Student</field>
<!--            <field name="category_id" ref="student_management.module_akhil_school"/>-->
        </record>

        <record id="rule_student_own_records" model="ir.rule">
            <field name="name">Student View Own Records</field>
            <field name="model_id" ref="model_students_management"/>
            <field name="groups" eval="[(4, ref('group_student'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
            <field name="perm_write" eval="0"/>
        </record>
        <record id="rule_teacher" model="ir.rule">
            <field name="name">Teachers Access Assigned Students</field>
            <field name="model_id" ref="model_students_management"/>
            <field name="groups" eval="[(4, ref('group_faculty'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
            <field name="perm_write" eval="1"/>
        </record>
        <record id="rule_Principal" model="ir.rule">
            <field name="name">Principal Access Assigned Students</field>
            <field name="model_id" ref="model_students_management"/>
            <field name="groups" eval="[(4, ref('group_principal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
            <field name="perm_write" eval="1"/>
        </record>
    </data>
</odoo>