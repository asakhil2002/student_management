<odoo>
    <record id="view_school_details" model="ir.ui.view">
        <field name="name">view.school.details</field>
        <field name="model">school.details</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="student"/>
            </list>
        </field>
    </record>
    <record id="view_school_form" model="ir.ui.view">
        <field name="name">view.school.form</field>
        <field name="model">school.details</field>
        <field name="arch" type="xml">
            <form>
                <div name="button_box" position="inside">
                    <button class="oe_stat_button btn-primary" type="object"
                            name="action_get_count">
                        <field string="Total" name="count" widget="statinfo"/>
                    </button>
                </div>

                <group>
                    <field name="name"/>
                </group>
                <notebook>
                    <page string="Student">
                        <field name="student">
                            <list>
                                <field name="name"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </form>
        </field>
    </record>
    <record id="action_school" model="ir.actions.act_window">
        <field name="name">School</field>
        <field name="res_model">school.details</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>